{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "functions": {
    "api/portfolio.ts": {
      "excludeFiles": "{client/public/**,dist/**}"
    },
    "api/contact.ts": {
      "excludeFiles": "{client/public/**,dist/**}"
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
